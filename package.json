{
  "name": "@cyqmq/cs2-inventory-app",
  "version": "3.0.0",
  "description": "CS2 Inventory Simulator Desktop Client",
  "main": "dist-electron/main.js",
  "author": "cyqmq",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build:electron": "node scripts/build-electron.mjs",
    "dev": "react-router dev",
    "dev:electron": "concurrently \"react-router dev\" \"wait-on http://localhost:5173 && electron .\"",
    "format": "prettier . --write",
    "lint": "eslint",
    "start:electron": "electron .",
    "test": "vitest",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-regular-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@ianlucas/cs2-lib": "^8.2.0",
    "@ianlucas/cs2-lib-inspect": "^8.1.0",

    "@uidotdev/usehooks": "^2.4.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.20",
    "isbot": "^5.1.44",
    "lz-string": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "remix-utils": "^8.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "^8.2.0",
    "@react-router/fs-routes": "^8.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "allowScripts": {
    "electron@35.7.5": true,
    "esbuild@0.28.1": true
  }
}
